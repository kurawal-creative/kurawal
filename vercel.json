{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "services": {
        "backend": {
            "root": "backend",
            "entrypoint": "src/server.ts"
        },
        "frontend": {
            "root": "frontend",
            "rewrites": [
                { "source": "/(.+\\..*)", "destination": "/$1" },
                { "source": "/(.*)", "destination": "/index.html" }
            ]
        }
    },
    "rewrites": [
        { "source": "/api/(.*)", "destination": { "service": "backend" } },
        { "source": "/(.*)", "destination": { "service": "frontend" } }
    ]
}
